# AutoBench environment variables
# Copy this to .env and fill in the values for your environment.

# HuggingFace token (required for gated model downloads)
HF_TOKEN=

# Weights & Biases API key (optional, for experiment logging)
WANDB_API_KEY=

# Dataset root paths — override defaults from dataset YAML configs.
# Set these to match your HPC or workstation paths.

# Ovarian cancer dataset root
AUTOBENCH_OVARIAN_ROOT=/path/to/ovarian/dataset

# CLWD lung adenocarcinoma dataset root
AUTOBENCH_CLWD_ROOT=/path/to/clwd/dataset

# Third dataset (placeholder)
# AUTOBENCH_PLACEHOLDER_ROOT=/path/to/third/dataset

# Hancock dataset root
# AUTOBENCH_HANCOCK_ROOT=/path/to/hancock/dataset

# ============================================================
# TCGA Datasets (GOLDMARK — 16 cancer types)
# Set these to your cluster paths before running feature extraction.
# See docs/tcga_feature_extraction_tutorial.md for setup instructions.
# ============================================================

# Leo (reference example)
AUTOBENCH_TCGA_LUAD_ROOT=/path/to/tcga_luad

# Yeonwoo (multimodal — pathology + radiology)
AUTOBENCH_TCGA_GBM_ROOT=/path/to/tcga_gbm
AUTOBENCH_TCGA_LGG_ROOT=/path/to/tcga_lgg
AUTOBENCH_TCGA_BRCA_ROOT=/path/to/tcga_brca
AUTOBENCH_TCGA_HNSC_ROOT=/path/to/tcga_hnsc
AUTOBENCH_TCGA_BLCA_ROOT=/path/to/tcga_blca

# Keishi
AUTOBENCH_TCGA_COAD_ROOT=/path/to/tcga_coad
AUTOBENCH_TCGA_UCEC_ROOT=/path/to/tcga_ucec
AUTOBENCH_TCGA_SKCM_ROOT=/path/to/tcga_skcm
AUTOBENCH_TCGA_THCA_ROOT=/path/to/tcga_thca
AUTOBENCH_TCGA_STAD_ROOT=/path/to/tcga_stad

# Ryan
AUTOBENCH_TCGA_CESC_ROOT=/path/to/tcga_cesc
AUTOBENCH_TCGA_TGCT_ROOT=/path/to/tcga_tgct
AUTOBENCH_TCGA_PAAD_ROOT=/path/to/tcga_paad
AUTOBENCH_TCGA_PCPG_ROOT=/path/to/tcga_pcpg
AUTOBENCH_TCGA_UCS_ROOT=/path/to/tcga_ucs
