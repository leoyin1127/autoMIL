# autoMIL Configuration
# This file configures autoMIL for your project.
# Edit the paths and settings below for your environment.

project:
  name: "{{ project_name }}"
  description: "TODO: Describe your task"

task:
  name: "{{ project_name }}"
  type: "{{ task_type }}"
  num_classes: 2
  label_column: "label"
  positive_label: 1

data:
  features_dir: "/path/to/features/"
  splits_dir: "/path/to/splits/"
  mapping_csv: "/path/to/mapping.csv"
  num_folds: 5
  seed: 42

encoders:
  primary: "{{ encoder }}"
  available:
    # TODO: Set correct dimension for your encoder
    {{ encoder }}: 1536

baseline:
  model: "clam_mb"
  framework: "CLAM"
  test_auc: 0.0
  composite: 0.0

metrics:
  primary: "composite"
  composite_formula: "(test_auc + test_bacc) / 2"
  track: ["val_auc", "val_bacc", "test_auc", "test_bacc"]

training:
  learning_rate: 3e-4
  weight_decay: 1e-4
  dropout: 0.25
  num_epochs: 100
  warmup_epochs: 5
  patience: 10
  batch_size: 32
  max_seq_length: 4096

files:
  # The agent scopes the codebase and determines what to edit.
  # These lists guide the agent and control automil submit auto-detect.
  editable: []       # TODO: list files the agent may modify
  readonly: []       # TODO: list files the agent should not modify

run:
  script: "train.py"              # training script name (relative to project root)
  command: null                   # optional: full command override (e.g., "python src/train.py --config config.yaml")

orchestrator:
  poll_interval_sec: 5
  safety_margin_gb: 2.0
  default_timeout_min: 150
  max_concurrent_per_gpu: 1
  default_vram_estimate_gb: 0.5

viz:
  port: 8420
  host: "0.0.0.0"

# --- Registry (Phase 1, REG-04 / REG-06 / REG-07) ---
registry:
  # Glob patterns the agent's overlay MUST NOT touch. Empty = no protection.
  # Add the shared library files / training-script entry points that should
  # only change via committed variant modules. Examples:
  #   - "benchmarks/lib/CLAM/**"
  #   - "src/models/clam/base.py"
  # NOTE: autoMIL ships no defaults here — only YOU know which files are
  # load-bearing for your project (D-33).
  protected: []

  # Search-scope mode: "free" (default, F2-aligned) or "architecture-preserving"
  # ("free" runs interface + purity validators; "architecture-preserving"
  # additionally runs identity-strict validation per identity_constraints.)
  mode: "free"

  # Reproduction tolerance for `automil verify-repro <node_id>` (default ±0.005).
  repro_tolerance: 0.005

  # Per-project identity constraints (used in architecture-preserving mode).
  # Examples: "param_count_pct: 5"  ("variant param count within 5% of parent")
  # Empty list disables structural identity checks beyond default dtype/rank.
  identity_constraints: []

# --- Variant selection (D-35, REG-07) ---
# The framework resolves these via registry.resolve_model(parent, variant) etc.
# Set after porting your first variant via `automil port-variant <node_id>`.
model:
  variant: null    # e.g. "clam_mb_v0176"
  parent: null     # e.g. "clam_mb"
loss:
  variant: null    # e.g. "ce_smooth008"
policy:
  variant: null    # e.g. "sam_lookahead"

# --- Backend configuration (Phase 6 / D-152..D-188) ---
# Select the job execution backend. Default "local" works on any machine.
# "slurm" requires: pip install -e '.[slurm]' + valid directives below.
# "ray"   requires: pip install -e '.[ray]'   + RAY_ADDRESS env var or local cluster.
backend:
  name: "local"            # "local" | "slurm" | "ray"

  slurm:
    # walltime_seconds is the framework-side cap value (D-155, RESEARCH.md OQ-1).
    # SLURMBackend converts this to submitit's timeout_min = max(1, walltime_seconds // 60).
    walltime_seconds: 21600       # 6h default; override per-campaign
    debug_in_process: false       # set true to use submitit cluster="debug" (CI/test only)
    directives:
      partition: "TODO_FILL_IN"   # required — operator-supplied; e.g. "compute"
      account: "TODO_FILL_IN"     # required — operator-supplied; e.g. "mylab"
      qos: null                   # optional — null disables; e.g. "high"
      cpus_per_task: 8            # required — integer
      mem_gb: 48                  # required — integer
      gpus_per_node: 1            # optional — defaults to 1 if omitted
      # NOTE: `signal` is framework-mandated as "B:TERM@30" (Phase 4 D-115 cap contract);
      # automil check rejects any operator override here.

  ray:
    # Hybrid init (D-161): try ray.init(address=RAY_ADDRESS or "auto"); on
    # ConnectionError fall back to local cluster IF allow_local_fallback is true.
    allow_local_fallback: true    # false → raise RayClusterUnreachableError if RAY_ADDRESS unreachable
